# Dev-only defaults for docker-compose. Copy to .env and adjust if needed.
# Never put real credentials here — .env is gitignored.
POSTGRES_USER=dsa
POSTGRES_PASSWORD=dsa
POSTGRES_DB=exam

# RS256_PRIVATE_KEY (exam) / RS256_PUBLIC_KEY (gateway, question): not set
# here. The dev keypair is committed at infra/dev-keys/ and wired directly
# into infra/docker-compose.yml. Never put real production key material in
# this file.

# Google OIDC (candidate sign-in). Get real values from Google Cloud
# Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# (console.cloud.google.com/apis/credentials). GOOGLE_CLIENT_ID must match
# the frontend's VITE_GOOGLE_CLIENT_ID (same OAuth client). GOOGLE_CLIENT_ID
# is the only one of the three actually read by the current client-side
# Google Identity Services flow — GOOGLE_CLIENT_SECRET and
# GOOGLE_REDIRECT_URI aren't consumed by any code path yet; they're
# validated at startup when ENV=production and reserved for a future
# server-side flow.
GOOGLE_CLIENT_ID=dev-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dev-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/invite
